{
  "id": "mpp",
  "name": "MPP",
  "description": "Makes OpenClaw HTTP requests payment-aware with MPP.",
  "version": "0.0.0",
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "tools": [
      "mpp_fetch"
    ]
  },
  "toolMetadata": {
    "mpp_fetch": {
      "optional": false,
      "replaySafe": false
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "description": "Enable payment-aware fetch at startup."
      }
    }
  }
}
