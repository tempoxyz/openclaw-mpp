{
  "name": "@tempoxyz/openclaw-mpp",
  "version": "0.0.0",
  "private": true,
  "description": "Official MPP plugin for OpenClaw.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tempoxyz/openclaw-mpp.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "mppx": "^0.8.5",
    "typebox": "^1.3.4",
    "viem": "^2.54.6"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.11"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "openclaw": "2026.6.11",
    "typescript": "^6.0.3"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "plugin": {
      "id": "mpp",
      "label": "MPP"
    },
    "install": {
      "clawhubSpec": "@tempoxyz/openclaw-mpp",
      "npmSpec": "@tempoxyz/openclaw-mpp",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=2026.6.11"
    },
    "compat": {
      "pluginApi": ">=2026.6.11",
      "minGatewayVersion": "2026.6.11"
    },
    "build": {
      "openclawVersion": "2026.6.11",
      "pluginSdkVersion": "2026.6.11"
    }
  }
}
