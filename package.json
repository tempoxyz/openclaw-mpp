{
  "name": "openclaw-mpp",
  "version": "0.2.1",
  "description": "Let OpenClaw call pay-per-use APIs using MPP with automatic HTTP 402 payments and a capped Tempo Wallet access key.",
  "keywords": [
    "agent-payments",
    "ai-agents",
    "http-402",
    "machine-payments",
    "mpp",
    "openclaw",
    "pay-per-use",
    "stablecoin",
    "tempo"
  ],
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/tempoxyz/openclaw-mpp#readme",
  "bugs": {
    "url": "https://github.com/tempoxyz/openclaw-mpp/issues"
  },
  "packageManager": "pnpm@11.0.8",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tempoxyz/openclaw-mpp.git"
  },
  "scripts": {
    "build": "node scripts/version.mjs --check && tsc -p tsconfig.json",
    "changeset:publish": "changeset publish",
    "changeset:version": "changeset version && node scripts/version.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint src tests",
    "test": "pnpm build && node --test",
    "prepack": "pnpm build"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "dependencies": {
    "accounts": "^0.15.2",
    "mppx": "^0.8.12",
    "typebox": "^1.3.4",
    "viem": "^2.54.6"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.11"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^24.0.10",
    "openclaw": "2026.7.1-2",
    "ox": "~0.14.30",
    "oxlint": "^1.72.0",
    "typescript": "^6.0.3"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "plugin": {
      "id": "mpp",
      "label": "MPP"
    },
    "install": {
      "clawhubSpec": "openclaw-mpp",
      "npmSpec": "openclaw-mpp",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=2026.6.11"
    },
    "compat": {
      "pluginApi": ">=2026.6.11",
      "minGatewayVersion": "2026.6.11"
    },
    "build": {
      "openclawVersion": "2026.6.11",
      "pluginSdkVersion": "2026.6.11"
    }
  }
}
