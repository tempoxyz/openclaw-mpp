{
  "name": "@tempoxyz/openclaw-mpp",
  "version": "0.1.0",
  "description": "Official MPP plugin for OpenClaw.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tempoxyz/openclaw-mpp.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint src tests",
    "test": "pnpm build && node --test",
    "prepack": "pnpm build"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "dependencies": {
    "mppx": "^0.8.6",
    "typebox": "^1.3.4",
    "viem": "^2.54.6"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.11"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "openclaw": "2026.6.11",
    "oxlint": "^1.72.0",
    "typescript": "^6.0.3"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "plugin": {
      "id": "mpp",
      "label": "MPP"
    },
    "install": {
      "clawhubSpec": "@tempoxyz/openclaw-mpp",
      "npmSpec": "@tempoxyz/openclaw-mpp",
      "defaultChoice": "clawhub",
      "minHostVersion": ">=2026.6.11"
    },
    "compat": {
      "pluginApi": ">=2026.6.11",
      "minGatewayVersion": "2026.6.11"
    },
    "build": {
      "openclawVersion": "2026.6.11",
      "pluginSdkVersion": "2026.6.11"
    }
  }
}
